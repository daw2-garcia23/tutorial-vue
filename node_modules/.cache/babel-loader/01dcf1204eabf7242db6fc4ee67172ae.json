{"ast":null,"code":"export default {\n  name: 'tabla-personas',\n  props: {\n    personas: Array\n  },\n  methods: {\n    editarPersona(persona) {\n      this.personaEditada = Object.assign({}, persona);\n      this.editando = persona.id;\n    }\n  },\n  data() {\n    return {\n      editando: null\n    };\n  }\n};","map":{"version":3,"mappings":"AAgDI,eAAe;EACfA,IAAI,EAAE,gBAAgB;EACtBC,KAAK,EAAE;IACHC,QAAQ,EAAEC;EACd,CAAC;EACDC,OAAO,EAAE;IACXC,aAAa,CAACC,OAAO,EAAE;MACrB,IAAI,CAACC,cAAa,GAAIC,MAAM,CAACC,MAAM,CAAC,CAAC,CAAC,EAAEH,OAAO,CAAC;MAChD,IAAI,CAACI,QAAO,GAAIJ,OAAO,CAACK,EAAE;IAC5B;EACF,CAAC;EACDC,IAAI,GAAG;IACL,OAAO;MACLF,QAAQ,EAAE;IACZ;EACF;AACA","names":["name","props","personas","Array","methods","editarPersona","persona","personaEditada","Object","assign","editando","id","data"],"sourceRoot":"","sources":["C:\\Users\\DAW2.T6PC17.000\\Desktop\\CursoVue\\tutorial-vue\\src\\components\\TablaPersonas.vue"],"sourcesContent":["<template>\r\n  <div id=\"tabla-personas\">\r\n    <div v-if=\"!personas.length\" class=\"alert alert-info\" role=\"alert\">\r\n      No se han agregado personas\r\n    </div>\r\n    <table class=\"table\">\r\n      <thead>\r\n        <tr>\r\n          <th>Nombre</th>\r\n          <th>Apellido</th>\r\n          <th>Email</th>\r\n          <th>Acciones</th>\r\n        </tr>\r\n      </thead>\r\n      <tbody>\r\n        <tr v-for=\"persona in personas\" :key=\"persona.id\">\r\n          <td v-if=\"editando === persona.id\">\r\n              <input type=\"text\" class=\"form-control\" v-model=\"persona.nombre\" />\r\n          </td>\r\n          <td v-else>\r\n              {{ persona.nombre}}\r\n          </td>\r\n          <td v-if=\"editando === persona.id\">\r\n              <input type=\"text\" class=\"form-control\" v-model=\"persona.apellido\" />\r\n          </td>\r\n          <td v-else>\r\n              {{ persona.apellido}}\r\n          </td>\r\n          <td v-if=\"editando === persona.id\">\r\n              <input type=\"email\" class=\"form-control\" v-model=\"persona.email\" />\r\n          </td>\r\n          <td v-else>\r\n              {{ persona.email}}\r\n          </td>\r\n          <td v-if=\"editando === persona.id\">\r\n            <button class=\"btn btn-success\" @click=\"guardarPersona(persona)\">💾 Guardar</button>\r\n            <button class=\"btn btn-secondary ml-2\" @click=\"cancelarEdicion(persona)\">❌ Cancelar</button>\r\n          </td>\r\n          <td v-else>\r\n            <button class=\"btn btn-info\" @click=\"editarPersona(persona)\">✏️ Editar</button>\r\n            <button class=\"btn btn-danger ml-2\" @click=\"$emit('delete-persona', persona.id)\">🗑️ Eliminar</button>\r\n          </td>\r\n        </tr>\r\n      </tbody>\r\n    </table>\r\n  </div>\r\n</template>\r\n  <script>\r\n    export default {\r\n    name: 'tabla-personas',\r\n    props: {\r\n        personas: Array,\r\n    },\r\n    methods: {\r\n  editarPersona(persona) {\r\n    this.personaEditada = Object.assign({}, persona);\r\n    this.editando = persona.id;\r\n  },\r\n},\r\ndata() {\r\n  return {\r\n    editando: null,\r\n  }\r\n}\r\n}\r\n  </script>\r\n  \r\n  <style scoped></style>"]},"metadata":{},"sourceType":"module"}