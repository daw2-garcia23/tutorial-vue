{"ast":null,"code":"export default {\n  name: 'formulario-persona',\n  data() {\n    return {\n      persona: {\n        procesando: false,\n        correcto: false,\n        error: false,\n        nombre: '',\n        persona: '',\n        apellido: ''\n      }\n    };\n  },\n  methods: {\n    enviarFormulario() {\n      this.procesando = true;\n      this.resetEstado();\n\n      // Comprobamos la presencia de errores\n      if (this.nombreInvalido || this.apellidoInvalido || this.emailInvalido) {\n        this.error = true;\n        return;\n      }\n      this.$emit('add-persona', this.persona);\n      this.error = false;\n      this.correcto = true;\n      this.procesando = false;\n\n      // Restablecemos el valor de la variables\n      this.persona = {\n        nombre: '',\n        apellido: '',\n        email: ''\n      };\n    },\n    resetEstado() {\n      this.correcto = false;\n      this.error = false;\n    },\n    computed: {\n      nombreInvalido() {\n        return this.persona.nombre.length < 1;\n      },\n      apellidoInvalido() {\n        return this.persona.apellido.length < 1;\n      },\n      emailInvalido() {\n        return this.persona.email.length < 1;\n      }\n    }\n  },\n  computed: {\n    nombreInvalido() {\n      return this.persona.nombre.length < 1;\n    },\n    apellidoInvalido() {\n      return this.persona.apellido.length < 1;\n    },\n    emailInvalido() {\n      return this.persona.email.length < 1;\n    }\n  }\n};","map":{"version":3,"mappings":"AAkEI,eAAe;EACbA,IAAI,EAAE,oBAAoB;EAC1BC,IAAI,GAAG;IACL,OAAO;MACLC,OAAO,EAAE;QACPC,UAAU,EAAE,KAAK;QACjBC,QAAQ,EAAE,KAAK;QACfC,KAAK,EAAE,KAAK;QACZC,MAAM,EAAE,EAAE;QACVJ,OAAO,EAAE,EAAE;QACXK,QAAQ,EAAE;MACZ;IACF;EACF,CAAC;EACDC,OAAO,EAAE;IACbC,gBAAgB,GAAG;MACjB,IAAI,CAACN,UAAS,GAAI,IAAI;MACtB,IAAI,CAACO,WAAW,EAAE;;MAElB;MACA,IAAI,IAAI,CAACC,cAAa,IAAK,IAAI,CAACC,gBAAe,IAAK,IAAI,CAACC,aAAa,EAAE;QACtE,IAAI,CAACR,KAAI,GAAI,IAAI;QACjB;MACF;MAEA,IAAI,CAACS,KAAK,CAAC,aAAa,EAAE,IAAI,CAACZ,OAAO,CA